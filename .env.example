# Brewery Manager Environment Configuration
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Security - CHANGE THIS IN PRODUCTION!
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# Database (default: SQLite in data directory)
DATABASE_PATH=data/brewery.db

# Backup Configuration
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# MiMo AI Configuration (Xiaomi MiMo Large Model)
MIMO_API_KEY=sk-squ1jojx107ar0ia9q4bonqrfiwek5ooukqfftu3vl21gqzy
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
